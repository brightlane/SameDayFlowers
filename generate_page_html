import os

def generate_page_html(city, state, config, BASE_URL, PROJECT_DIR, DEADLINE, MANYCHAT_LINK):
    filename = f"flowers-{city.lower().replace(' ', '-')}-{state.lower()}.html"
    page_url = f"{BASE_URL}/{PROJECT_DIR}/{filename}"

    affiliate_id = config.get("affiliate_id", "2013017799")
    partner_id = config.get("manychat_partner_id", "")

    html_content = f"""<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Same Day Flowers {city}, {state} | Local Delivery</title>

    <meta name="description" content="Send Mother's Day flowers in {city}, {state}. Guaranteed delivery by {DEADLINE}.">
    <link rel="canonical" href="{page_url}">

    <meta name="geo.region" content="US-{state.upper()}">
    <meta name="geo.placename" content="{city}">

    <style>
        body {{ font-family: Arial; margin:0; background:#fff; }}
        .btn {{
            background:#ff4d6d;
            color:#fff;
            padding:18px 40px;
            display:inline-block;
            text-decoration:none;
            border-radius:50px;
            font-weight:bold;
        }}
    </style>
</head>

<body>

    <header style="text-align:center;padding:60px 20px;">
        <h1>Flowers in {city}</h1>
        <p>Delivered same-day by local florists in {state}</p>

        <!-- PRIMARY CTA = AFFILIATE (FIXED) -->
        <a class="btn"
           href="http://www.floristone.com/main.cfm?AffiliateID={affiliate_id}&source_id=brightlane&occ=mothersday">
           BUY FLOWERS NOW
        </a>

        <br><br>

        <!-- SECONDARY CTA = MANYCHAT -->
        <a class="btn" style="background:#444;"
           href="{MANYCHAT_LINK}">
           CHECK AVAILABILITY
        </a>
    </header>

    <main style="padding:40px;text-align:center;">
        <p>Local dispatch network active in {city}, {state}.</p>
    </main>

    <footer style="text-align:center;padding:40px;font-size:12px;color:#888;">
        Affiliate ID: {affiliate_id} | Partner: {partner_id}
    </footer>

</body>
</html>"""

    file_path = os.path.join(PROJECT_DIR, filename)
    os.makedirs(PROJECT_DIR, exist_ok=True)

    with open(file_path, "w", encoding="utf-8") as f:
        f.write(html_content)

    return filename
