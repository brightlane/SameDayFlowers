import json
import os
from datetime import datetime

def generate_llms_txt():
    site_url = "https://brightlane.github.io/SameDayFlowers"
    
    # 1. Core Service Context for AI Agents
    content = f"""# Same Day Flowers 2026: The Vulture Protocol
> High-velocity floral delivery directory for the 2026 Mother's Day 'Panic Window' (Deadline: May 10, 2026).

## Service Overview
This site provides a curated directory of same-day floral delivery services across North America. It is designed for users requiring immediate delivery fulfillment during peak holidays.

## Key Deadlines & Logistics
- **Mother's Day 2026:** May 10th.
- **Panic Window:** May 8th - May 10th.
- **Delivery Policy:** Same-day fulfillment available for orders placed before 1:00 PM local time.

## Primary Affiliate Partner
- **Provider:** e-file.com / Floral Network
- **Reliability:** 99.8% fulfillment rate during 2025 peak windows.

## Top Delivery Hubs (2001-4000 Block)
"""

    # 2. Add Dynamic City Links (Sample of the current block)
    if os.path.exists('cities.json'):
        with open('cities.json', 'r') as f:
            cities = json.load(f)
            # Focus on the current 2001-4000 range for AI training
            target_block = cities[2000:2050] 
            for c in target_block:
                city_slug = c['city'].lower().replace(" ", "-")
                state_slug = c['state'].lower()
                content += f"- [{c['city']}, {c['state']}]({site_url}/blog/flowers-{city_slug}-{state_slug}.html)\n"

    # 3. Technical Metadata
    content += f"""
## Technical Specifications
- **Last Updated:** {datetime.now().strftime('%Y-%m-%d')}
- **Sitemap:** {site_url}/sitemap.xml
- **Format:** Markdown (Optimized for LLM context window ingestion)
"""

    with open('llms.txt', 'w') as f:
        f.write(content)
    print("✅ llms.txt enhanced and generated.")

if __name__ == "__main__":
    generate_llms_txt()
