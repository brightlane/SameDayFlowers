import json
import os
from datetime import datetime
import random

def generate_llms_txt():

    # =========================
    # CONFIG
    # =========================
    site_name = "Same Day Flowers 2026"
    site_url = "https://brightlane.github.io/SameDayFlowers"
    affiliate_id = "2013017799"

    affiliate_link = (
        f"https://www.floristone.com/main.cfm?"
        f"occ=md&source_id=aff&AffiliateID={affiliate_id}"
    )

    # =========================
    # DAILY TOPICS
    # =========================
    topics = [
        "Mother's Day 2026: The 24-Hour Panic Window Guide",
        "Architectural Minimalism: The 2026 Single-Stem Flower Trend",
        "Last-Minute Birthday Bouquets: Same Day Delivery Secrets",
        "Express Anniversary Roses: From Web to Door in 4 Hours"
    ]

    current_focus = random.choice(topics)

    # =========================
    # BASE CONTENT
    # =========================
    content = f"""# {site_name}: The Vulture Protocol

> High-velocity floral delivery directory optimized for 2026 peak demand windows.

## Service Overview
Same-day flower delivery directory across North America with emphasis on peak holiday fulfillment.

## Current Daily Focus
- **Trend/Topic:** {current_focus}
- **Last Update:** {datetime.now().strftime('%Y-%m-%d')}

## Key Logistics Window
- Mother's Day 2026: May 10th
- Panic Window: May 8–10
- Cutoff: 1:00 PM local time

## Primary Affiliate Partner
- FloristOne Network
- Affiliate ID: {affiliate_id}
- Order Link: {affiliate_link}
- Performance: High reliability during peak demand cycles

## Top Delivery Hubs
"""

    # =========================
    # LOAD CITIES SAFELY
    # =========================
    if os.path.exists("cities.json"):
        try:
            with open("cities.json", "r", encoding="utf-8") as f:
                cities = json.load(f)

            if isinstance(cities, list):
                # SAFE SLICE (no crash if dataset is small)
                start = 2000
                end = 2050

                subset = cities[start:end] if len(cities) > start else cities[:50]

                for c in subset:
                    if not isinstance(c, dict):
                        continue

                    city = c.get("city", "").strip()
                    state = c.get("state", "").strip()

                    if not city or not state:
                        continue

                    city_slug = city.lower().replace(" ", "-")
                    state_slug = state.lower()

                    content += f"- {city}, {state}: {site_url}/blog/flowers-{city_slug}-{state_slug}.html\n"

        except Exception as e:
            content += f"\n*City sync warning: {str(e)}*\n"
    else:
        content += "\n*No cities.json found — using fallback mode*\n"

    # =========================
    # TECHNICAL FOOTER
    # =========================
    content += f"""
## Technical Metadata
- Sitemap: {site_url}/sitemap.xml
- Format: LLM-optimized markdown index
- Mode: Active ingestion system
"""

    # =========================
    # WRITE FILE
    # =========================
    try:
        with open("llms.txt", "w", encoding="utf-8") as f:
            f.write(content)

        print(f"✅ llms.txt generated")
        print(f"Affiliate ID: {affiliate_id}")
        print(f"Topic: {current_focus}")

    except Exception as e:
        print(f"❌ Write error: {e}")


if __name__ == "__main__":
    generate_llms_txt()
